from __future__ import annotations

import re
import subprocess
from pathlib import Path
from urllib.request import urlopen

KORG = "https://cdn.kernel.org/pub/linux/kernel"

ASC = re.compile(rb"([0-9a-f]{64})  linux-([0-9rc.-]+)\.tar\.xz\n")
REF = re.compile(rb"([0-9a-f]{40})\trefs/tags/(v[0-9rc.-]+)\^{}\n")
TAG = re.compile(
    r"v([3-9])\.([0-9]+)(?:-rc(?P<rc>[1-9][0-9]*)|\.(?P<stable>[1-9][0-9]*)|)"
)


data = {}
for subdir in ["v3.x", "v4.x", "v5.x", "v6.x"]:
    url = f"{KORG}/{subdir}/sha256sums.asc"
    print(f"Downloading {url}")
    with urlopen(url) as res:  # noqa: S310
        for line in res:
            if match := ASC.fullmatch(line):
                sha256 = match.group(1).decode("ascii")
                version = match.group(2).decode("ascii")
                tag = f"v{version}"
                entry = data.setdefault(tag, {})
                entry["path"] = f"{subdir}/linux-{version}.tar.xz"
                entry["sha256"] = sha256

tags = {}
cmd = [
    "git",
    "ls-remote",
    "--tags",
    "https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git",
]
print(f"+ {' '.join(cmd)}")
with subprocess.Popen(cmd, stdout=subprocess.PIPE) as git:
    for line in git.stdout:
        if match := REF.fullmatch(line):
            sha = match.group(1).decode("ascii")
            tag = match.group(2).decode("ascii")
            tags[tag] = sha

for tag, entry in data.items():
    entry["commit"] = tags[tag]


def vercomp(version: str) -> (int, int, int):
    m = TAG.fullmatch(version)
    if not m:
        return 1000, 1000, 1000
    major = int(m.group(1))
    minor = int(m.group(2))
    if rc := m.group("rc"):
        last = int(rc)
    elif stable := m.group("stable"):
        last = 1000 + int(stable)
    else:
        last = 1000
    return major, minor, last


def write_toml(file: Path) -> None:
    with file.open("w") as out:
        out.write("# Generated by ukpack update-releases\n")
        for tag in sorted(data.keys(), key=vercomp):
            out.write(f'["{tag}"]\n')
            entry = data[tag]
            for key in ["commit", "path", "sha256"]:
                out.write(f'{key}="{entry[key]}"\n')


here = Path(__file__).resolve(strict=True).parent
print("Writing ubuntu/releases.toml")
write_toml(here / "ubuntu" / "releases.toml")
