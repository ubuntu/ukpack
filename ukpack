def create_source_pkg_native(
    config: Config, dest: pathlib.Path, build: pathlib.Path, repo: pathlib.Path
):
    source = config["pkg"]["source"]["Source"]
    debian = build / "debian"
    print("Creating debian directory")
    create_debian(config, debian)

    tarball = f"{source}_{config['version']}.tar.xz"
    print(f"Creating {tarball}")
    with Spawn(
        "git",
        "archive",
        "--format=tar",
        f"--prefix={source}/",
        config["head"],
        ":(exclude)debian/",
        stdout=subprocess.PIPE,
        cwd=repo,
    ) as git:
        with Spawn(
            "xz",
            "--verbose",
            "--threads=0",
            "--compress",
            "--stdout",
            stdin=subprocess.PIPE,
            stdout=dest / tarball,
            cwd=dest,
        ) as xz:
            with tarfile.open(mode="w|", fileobj=xz.stdin) as out:
                try:
                    with tarfile.open(mode="r|", fileobj=git.stdout) as git_archive:
                        while info := git_archive.next():
                            file = (
                                git_archive.extractfile(info) if info.isfile() else None
                            )
                            out.addfile(numeric_owner(info), fileobj=file)
                except tarfile.ReadError as e:
                    if str(e) != "empty file":
                        raise e
                out.add(
                    debian, f"{source}/debian", recursive=True, filter=numeric_owner
                )

    print(f"Creating {source}_{config['version']}.dsc")
    Spawn(
        "dpkg-source",
        "--format=3.0 (custom)",
        "--target-format=3.0 (native)",
        "--build",
        source,
        tarball,
        cwd=dest,
    ).check_returncode()


def create_source_pkg(
    config: Config,
    dest: pathlib.Path,
    repo: pathlib.Path,
    orig: Optional[pathlib.Path],
):
    source = config["pkg"]["source"]["Source"]
    build = dest / source
    build.mkdir(mode=0o755)

    buildinfo_file = f"{source}_{config['version']}_source.buildinfo"
    changes_file = f"{source}_{config['version']}_source.changes"

    try:
        if "orig" in config:
            create_source_pkg_quilt(config, dest, build, repo, orig)
        else:
            create_source_pkg_native(config, dest, build, repo)

        print(f"Creating {buildinfo_file}")
        Spawn("dpkg-genbuildinfo", "--build=source", cwd=build).check_returncode()

        print(f"Creating {changes_file}")
        Spawn(
            "dpkg-genchanges", "--build=source", f"-O../{changes_file}", cwd=build
        ).check_returncode()
    finally:
        shutil.rmtree(build)

    print("Source package built successfully \\o/")
    print(f"Sign package:    debsign {dest / changes_file}")
    print(f"Upload package:  dput <PPA> {dest / changes_file}")


def run() -> int:
    def eprint(*args, **kwargs) -> int:
        print(*args, file=sys.stderr, **kwargs)
        return 1

    cli = parse_args()
    try:
        config = Config(cli.datadir, cli.config)
    except ValueError as e:
        return eprint(str(e))
    except FileNotFoundError as e:
        return eprint(f"{e.strerror}: '{e.filename}'")

    try:
        if cli.debian:
            create_debian(config, cli.dest / "debian")
        else:
            create_source_pkg(config, cli.dest, cli.tree, cli.orig)
    except ValueError as e:
        return eprint(str(e))
    except FileExistsError as e:
        return eprint(f"Error creating '{e.filename}': {e.strerror}")
    except FileNotFoundError as e:
        return eprint(f"Error opening '{e.filename}': {e.strerror}")
    except KeyboardInterrupt:
        return eprint("interrupted")
    except subprocess.CalledProcessError as e:
        return e.returncode

    return 0


if __name__ == "__main__":
    sys.exit(run())
