#

# Do not use make's built-in rules and variables
# (this increases performance and avoids hard-to-debug behaviour)
MAKEFLAGS += -rR
.ONESHELL:
.SHELLFLAGS = -exc

# Used when you need to 'escape' a comma.
comma := ,
empty :=
space := $(empty) $(empty)

# Allow to run debian/rules directly without root
export DEB_RULES_REQUIRES_ROOT := no

export LC_ALL=C.UTF-8
#export SHELL=/bin/bash -e

# dpkg-buildpackage passes options that are incomptatible with the kernel build.
unexport CFLAGS
unexport LDFLAGS
ifeq ($(CC),cc)
undefine CC
endif

# Set these variables when not called by dpkg-buildpackage
DEB_BUILD_ARCH			?= $(shell dpkg-architecture -qDEB_BUILD_ARCH)
DEB_BUILD_GNU_TYPE		?= $(shell dpkg-architecture -qDEB_BUILD_GNU_TYPE)
DEB_HOST_ARCH			?= $(shell dpkg-architecture -qDEB_HOST_ARCH)
DEB_HOST_GNU_TYPE		?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
export DEB_BUILD_ARCH		:= $(DEB_BUILD_ARCH)
export DEB_BUILD_GNU_TYPE	:= $(DEB_BUILD_GNU_TYPE)
export DEB_HOST_ARCH		:= $(DEB_HOST_ARCH)
export DEB_HOST_GNU_TYPE	:= $(DEB_HOST_GNU_TYPE)

packages-indep	:= $(shell dh_listpackages -i)
packages-arch	:= $(shell dh_listpackages -a)

include debian/config.mk

config			:= $(config-$(DEB_HOST_ARCH))
tools			:= $(tools-$(DEB_HOST_ARCH))
cc			:= $(cc-$(DEB_HOST_ARCH))
vdso-install		:= $(vdso-install-$(DEB_HOST_ARCH))
install-mod-strip	:= $(install-mod-strip-$(DEB_HOST_ARCH))
force-compress-modules	:= $(force-compress-modules-$(DEB_HOST_ARCH))
ukify			:= $(ukify-$(DEB_HOST_ARCH))

karch-i386	:= x86
karch-x32	:= x86
karch-amd64	:= x86
karch-armhf	:= arm
karch-arm64	:= arm64
karch-powerpc	:= powerpc
karch-ppc64el	:= powerpc
karch-riscv64	:= riscv
karch-s390x	:= s390
karch		:= $(karch-$(DEB_HOST_ARCH))

efiarch-i386	:= ia32
efiarch-x32	:= unknown
efiarch-amd64	:= x64
efiarch-armhf	:= arm
efiarch-arm64	:= aa64
efiarch-powerpc	:= unknown
efiarch-ppc64el	:= unknown
efiarch-riscv64	:= riscv64
efiarch-s390x	:= unknown
efiarch		:= $(efiarch-$(DEB_HOST_ARCH))

ifneq ($(filter cross,$(DEB_BUILD_PROFILES)),)
ARCH		:= $(karch)
CROSS_COMPILE	:= $(DEB_HOST_GNU_TYPE)-
else ifneq ($(DEB_BUILD_ARCH),$(DEB_HOST_ARCH))
$(error Cross-compiling without the cross build profile. Please use dpkg-buildpackage -Pcross ..)
endif

ifeq ($(filter linux-tools-%,$(packages-arch)),)
tools		:=
endif

ifneq ($(cc),)
  ifneq ($(filter clang-%,$(cc)),)
    LLVM := -$(lastword $(subst -,$(space),$(cc)))
  else ifeq ($(cc),clang)
    LLVM := 1
  else ifeq ($(CC),)
    CC := $(CROSS_COMPILE)$(cc)
  endif
endif

JOBS := $(subst parallel=,,$(filter parallel=%,$(subst $(comma),$(space),$(DEB_BUILD_OPTIONS))))

KMAKE := $(strip $(MAKE) \
	$(if $(JOBS),-j$(JOBS)) \
	$(if $(ARCH),ARCH=$(ARCH)) \
	$(if $(CROSS_COMPILE),$(if $(LLVM),,CROSS_COMPILE=$(CROSS_COMPILE))) \
	$(if $(CC),CC=$(CC)) \
	$(if $(HOSTCC),HOSTCC=$(HOSTCC)) \
	$(if $(LLVM),LLVM=$(LLVM)) \
	KERNELRELEASE='$(krel)' \
	KBUILD_BUILD_VERSION='$(upload-number)' \
	CFLAGS_MODULE='-DPKG_ABI=$(abi-number)')

lock     := flock -w 60 -xF debian/lock
pkgname   = $(@:debian/%.stamp=%)
packages  = $(packages-indep) $(packages-arch)
lmms     := $(patsubst linux-main-modules-%-$(krel),%,$(filter linux-main-modules-%,$(packages-arch)))

.PHONY: all
all: binary

# Debian Build System targets
.PHONY: build
build: build-indep build-arch

.PHONY: binary
binary: binary-indep binary-arch

.PHONY: clean
clean:
	@rm -rf .config \
	  $(patsubst %,debian/%,$(packages)) \
	  $(patsubst %,debian/%.*,$(packages))
	dh_clean

.PHONY: build-indep
build-indep:
	@: === $@ ===

.PHONY: build-arch
build-arch: vmlinux $(tools:%=build-%) $(lmms:%=build-lmm-%)
	@: === $@ ===

.PHONY: binary-indep
binary-indep: $(packages-indep:%=debian/%.stamp) | build-indep
	@: === $@ ===

.PHONY: binary-arch
binary-arch: $(packages-arch:%=debian/%.stamp) | build-arch
	@: === $@ ===

include debian/rules.d/*.mk
